# =============================================================================
# .gitignore  —  Explainable Deepfake Detection (PyTorch research repo)
#
# Tracked: code, YAML configs, small markdown/text, requirements*.txt,
#          pyproject.toml, paths.example.yaml.
# Never tracked: datasets, extracted face crops, model weights, large outputs,
#          environments, and any local config holding real paths or secrets.
#
# Anchoring note: generic data/output dir names are ROOT-ANCHORED with a leading
# "/" so they only match the top level. This is deliberate — an unanchored
# "data/" would also ignore the dataset *config* files under configs/data/,
# which we DO want tracked.
# =============================================================================

# ---------------------------------------------------------------------------
# Datasets — NEVER commit (large; some are license-restricted).
# They are mounted/available on the remote GPU and referenced via paths.yaml.
# ---------------------------------------------------------------------------
/data/
/datasets/
# Exclude by dataset name anywhere in the tree (these names won't collide with
# any tracked config/code file):
**/FaceForensics++/
**/FaceForensics/
**/Celeb-DF-v2/
**/Celeb-DF/
**/DFDC/
**/WildDeepfake/
**/DF40/

# ---------------------------------------------------------------------------
# Extracted / aligned face crops — regenerated by scripts/preprocess_faces.py.
# ---------------------------------------------------------------------------
/crops/
**/crops/
**/faces/
**/*_faces/
**/*_crops/
**/aligned/
**/aligned_faces/

# ---------------------------------------------------------------------------
# Model checkpoints / weights — share the final .pth via cloud, not git (README).
# ---------------------------------------------------------------------------
*.pth
*.pt
*.ckpt
*.onnx
*.safetensors
*.bin
/checkpoints/
**/checkpoints/
/weights/
**/weights/

# ---------------------------------------------------------------------------
# Large output artifacts — logs, tensorboard runs, figures, result dumps.
# ---------------------------------------------------------------------------
/outputs/
/logs/
*.log
/runs/
**/runs/
/figures/
**/tb_logs/
wandb/
# Metrics dumps & result tables. Note: results/* (not results/) — a trailing-slash
# dir exclusion stops git from descending into the folder, making the .gitkeep
# negation a silent no-op. Ignoring the *contents* keeps the dir tracked via .gitkeep.
# (Comment kept on its own line: an inline '# ...' after a pattern becomes part of
#  the pattern in .gitignore, which silently breaks the match.)
experiments/results/*
!experiments/results/.gitkeep

# ---------------------------------------------------------------------------
# Python / packaging cruft
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.installed.cfg
*.egg

# ---------------------------------------------------------------------------
# Jupyter / IPython
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py

# ---------------------------------------------------------------------------
# Test / lint / type caches
# ---------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# ---------------------------------------------------------------------------
# Environments
# ---------------------------------------------------------------------------
.venv/
.venv-preprocess/
venv/
env/
ENV/
.conda/
*.conda

# ---------------------------------------------------------------------------
# Local config with real paths / secrets — copy paths.example.yaml -> paths.yaml
# ---------------------------------------------------------------------------
paths.yaml
*.local.yaml
*.local.yml
.env
.env.*
secrets.*
*.secret

# ---------------------------------------------------------------------------
# Editor / OS
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

dlib_tools/
*.dat
